<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Spark AI | Origin Spark Labs</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/tokyo-night-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    
    <style>
        * { box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body { background: #020617; color: #f8fafc; margin: 0; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
        
        header { padding: 15px 20px; background: #0f172a; border-bottom: 1px solid #1e293b; display: flex; justify-content: space-between; align-items: center; z-index: 10; }
        .logo { font-weight: 800; font-size: 1.2rem; color: #f8fafc; letter-spacing: 1px; }
        .logo span { color: #38bdf8; }
        
        .head-btns { display: flex; gap: 8px; }
        button.small { background: #1e293b; border: 1px solid #334155; color: #94a3b8; padding: 6px 12px; border-radius: 8px; cursor: pointer; font-size: 0.75rem; }

        #chat-container { flex: 1; overflow-y: auto; padding: 25px; display: flex; flex-direction: column; gap: 20px; background: radial-gradient(circle at top right, #0f172a, #020617); }
        
        .message { max-width: 85%; padding: 14px 20px; border-radius: 18px; font-size: 0.95rem; line-height: 1.5; animation: fadeIn 0.3s ease; position: relative; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }

        .user-message { align-self: flex-end; background: #38bdf8; color: #020617; border-bottom-right-radius: 4px; }
        .ai-message { align-self: flex-start; background: rgba(30, 41, 59, 0.7); border: 1px solid #334155; border-bottom-left-radius: 4px; backdrop-filter: blur(10px); }
        .ai-name { font-size: 0.65rem; font-weight: bold; color: #38bdf8; margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 1px; }

        pre { background: #000; padding: 15px; border-radius: 10px; overflow-x: auto; border: 1px solid #334155; margin-top: 10px; }
        
        .footer-area { background: #0f172a; border-top: 1px solid #1e293b; padding: 15px 20px; }
        .input-area { display: flex; gap: 10px; margin-bottom: 10px; }
        input { flex: 1; background: #020617; border: 1px solid #334155; color: white; padding: 14px; border-radius: 12px; outline: none; }
        
        .btn-action { padding: 14px; border-radius: 12px; cursor: pointer; border: none; font-weight: bold; }
        .mic-btn { background: #1e293b; color: white; border: 1px solid #334155; width: 50px; }
        .send-btn { background: #38bdf8; color: #020617; padding: 0 25px; }
        .mic-active { background: #ef4444; box-shadow: 0 0 10px #ef4444; }

        .signature { text-align: center; font-size: 0.65rem; color: #475569; letter-spacing: 1px; text-transform: uppercase; line-height: 1.5; }
        .signature b { color: #94a3b8; }
        .signature span { color: #38bdf8; }
    </style>
</head>
<body>

    <header>
        <div class="logo">SPARK <span>AI</span></div>
        <div class="head-btns">
            <button class="small" onclick="exportPDF()">📥 PDF</button>
            <button class="small" onclick="clearMemory()">🗑️ Reset</button>
        </div>
    </header>

    <div id="chat-container"></div>

    <div class="footer-area">
        <div class="input-area">
            <button class="btn-action mic-btn" id="mic-btn" onclick="startVoice()">🎙️</button>
            <input type="text" id="user-input" placeholder="Message Spark AI..." onkeypress="if(event.key==='Enter')sendMessage()">
            <button class="btn-action send-btn" onclick="sendMessage()">SEND</button>
        </div>
        <div class="signature">
            Created by <span>Origin Spark Labs</span><br>
            <b>Founded by Abdulaleem</b>
        </div>
    </div>

    <script>
        const chatBox = document.getElementById('chat-container');
        const userInput = document.getElementById('user-input');

        let memory = JSON.parse(localStorage.getItem('spark_pro_v3')) || [
            { role: 'ai', text: 'Spark AI Online. Systems secured by Origin Spark Labs.' }
        ];

        function save() { localStorage.setItem('spark_pro_v3', JSON.stringify(memory)); }
        function render() {
            chatBox.innerHTML = '';
            memory.forEach(m => addBubble(m.text, m.role));
        }

        function addBubble(text, role) {
            const div = document.createElement('div');
            div.className = `message ${role === 'user' ? 'user-message' : 'ai-message'}`;
            if(role === 'ai') {
                const nameTag = document.createElement('span');
                nameTag.className = 'ai-name';
                nameTag.innerText = 'Spark AI';
                div.appendChild(nameTag);
            }
            const content = document.createElement('span');
            if (text.includes('```')) {
                const parts = text.split('```');
                content.innerHTML = `${parts[0]}<pre><code>${parts[1]}</code></pre>${parts[2] || ''}`;
                const codeBlock = content.querySelector('code');
                if(codeBlock) hljs.highlightElement(codeBlock);
            } else {
                content.innerText = text;
            }
            div.appendChild(content);
            chatBox.appendChild(div);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        function sendMessage() {
            const val = userInput.value.trim();
            if (!val) return;
            memory.push({ role: 'user', text: val });
            addBubble(val, 'user-message');
            userInput.value = '';
            save();

            setTimeout(() => {
                const reply = botLogic(val);
                memory.push({ role: 'ai', text: reply });
                addBubble(reply, 'ai-message');
                save();
            }, 600);
        }

        function botLogic(input) {
            const s = input.toLowerCase();
            if (s.includes("founder") || s.includes("who is abdulaleem")) return "Abdulaleem is the founder of Origin Spark Labs and the lead architect behind my systems.";
            if (s.includes("who created you")) return "I was created by Origin Spark Labs, founded by Abdulaleem.";
            if (s.includes("code")) return "Accessing Spark Archives...\n```javascript\n// System Signature\nconst creator = 'Origin Spark Labs';\nconst founder = 'Abdulaleem';\n```";
            return "Copy that. Instruction processed at Spark Labs core.";
        }

        function startVoice() {
            const rec = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
            const btn = document.getElementById('mic-btn');
            btn.classList.add('mic-active');
            rec.start();
            rec.onresult = (e) => {
                userInput.value = e.results[0][0].transcript;
                btn.classList.remove('mic-active');
                sendMessage();
            };
            rec.onerror = () => btn.classList.remove('mic-active');
        }

        async function exportPDF() {
            const { jsPDF } = window.jspdf;
            const canvas = await html2canvas(chatBox, { backgroundColor: '#020617', scale: 2 });
            const doc = new jsPDF('p', 'mm', 'a4');
            doc.text("Official Spark AI Export | Founded by Abdulaleem", 10, 10);
            doc.addImage(canvas.toDataURL('image/png'), 'PNG', 10, 20, 190, (canvas.height * 190) / canvas.width);
            doc.save("Origin_Spark_AI_Log.pdf");
        }

        function clearMemory() { localStorage.clear(); location.reload(); }
        render();
    </script>
</body>
</html>
